rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All user-scoped data lives under /users/{uid}/**
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
